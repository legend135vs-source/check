# ENVIRONMENT
ENVIRONMENT=development
LOG_LEVEL=INFO

# DATABASE
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_vehicle_inspector

# REDIS
REDIS_URL=redis://localhost:6379/0

# OPENAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# CLOUDFLARE R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=ai-vehicle-inspector
R2_PUBLIC_URL=https://your-bucket.r2.dev

# EXTERNAL APIs
VIN_API_KEY=your_vin_api_key
VIN_API_URL=https://vpic.nhtsa.dot.gov/api
AUTO_RIA_API_KEY=your_auto_ria_key
AUTO_RIA_API_URL=https://developers.ria.com

# PDF ENGINE: weasyprint | reportlab
PDF_ENGINE=weasyprint

# ADMIN (hidden route segment)
ADMIN_SECRET_PATH=admin-x7k2

# FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
